###############################################################################
# use_ssh_key
###############################################################################
use_ssh_key() {
  HOST=
  while [ $# -gt 0 ]; do
    key="$1"

    case $key in
      -h|--host)
        HOST="$2"
        shift # past argument
        shift # past value
        ;;
      *)    # unknown option
        shift # past argument
        ;;
    esac
  done

  [ -z "$HOST" ] && die "--host not specified"

  [ -z "$SSH_AUTH_SOCK" ] && die "SSH_AUTH_SOCK not defined - is ssh-agent running? run systemctl enable --now --user ssh-agent.service"

  HOST_FILE_HOST=$(find_host_file "$HOST")
  [ -z "$HOST_FILE_HOST" ] && die "Could not find host key"

  KEY_BASE_NAME="id_$HOST_FILE_HOST"

  PRIVATE_KEY_FILENAME="$SSH_KEY_DIR/$KEY_BASE_NAME"
  PUBLIC_KEY_FILENAME="$SSH_KEY_DIR/$KEY_BASE_NAME.pub"
  [ ! -f "$PRIVATE_KEY_FILENAME" ] && die "Private key does not exist: $PRIVATE_KEY_FILENAME"
  [ ! -f "$PUBLIC_KEY_FILENAME" ] && die "Public key does not exist: $PUBLIC_KEY_FILENAME"
  [ -f "$PUBLIC_KEY_FILENAME" ] && cat "$PUBLIC_KEY_FILENAME"

  ssh-add "$PRIVATE_KEY_FILENAME"
  info "Loaded Keys:"
  ssh-add -l
}

###############################################################################
# import_ssh_key
###############################################################################
import_ssh_key() {
  HOST=
  SOURCE=
  while [ $# -gt 0 ]; do
    key="$1"

    case $key in
      -h|--host)
        HOST="$2"
        shift # past argument
        shift # past value
        ;;
      -s|--source)
        SOURCE="$2"
        shift # past argument
        shift # past value
        ;;
      *)    # unknown option
        shift # past argument
        ;;
    esac
  done

  [ -z "$HOST" ] && die "--host not specified"
  [ -z "$SOURCE" ] && die "--source not specified"

  HOST_FILE_HOST=$(find_host_file "$HOST")
  [ -z "$HOST_FILE_HOST" ] || die "Host already in the SSH config"

  KEY_BASE_NAME="id_$HOST"
  PRIVATE_KEY_FILENAME="$SSH_KEY_DIR/$KEY_BASE_NAME"
  PUBLIC_KEY_FILENAME="$SSH_KEY_DIR/$KEY_BASE_NAME.pub"
  [ -f "$PRIVATE_KEY_FILENAME" ] && die "Private key already exists: $PRIVATE_KEY_FILENAME"
  [ -f "$PUBLIC_KEY_FILENAME" ] && die "Public key already exists: $PUBLIC_KEY_FILENAME"

  [ ! -f "$SOURCE" ] && die "Source private key does not exist: $SOURCE"
  [ ! -f "$SOURCE.pub" ] && die "Source public key does not exist: $SOURCE.pub"

  ssh-keygen -l -f "$SOURCE" || die "$SOURCE: invalid private key"
  ssh-keygen -l -f "$SOURCE.pub" || die "$SOURCE.pub: invalid private key"

  cp "$SOURCE" "$PRIVATE_KEY_FILENAME"
  cp "$SOURCE.pub" "$PUBLIC_KEY_FILENAME"

  add_config_host_entry "$HOST" "$KEY_BASE_NAME"
}

###############################################################################
# remove_from_key_server
# Soft-failure helper: removes a key from the key server using challenge-response.
# If KEYS_SERVER_URL is unset, curl/jq missing, or .keyserver-id absent, emits
# a warning and returns 0 so the local operation is never blocked.
# Args: REMOVE_HOST        - API {host} segment
#       REMOVE_USER        - API {user} segment
#       REMOVE_PRIVATE_KEY - path to private key used to sign the challenge
###############################################################################
remove_from_key_server() {
  RMV_HOST=$1
  RMV_USER=$2
  RMV_PRIVATE_KEY=$3

  if [ -z "$KEYS_SERVER_URL" ]; then
    info "Warning: KEYS_SERVER_URL not set — skipping server removal"
    return 0
  fi
  if ! command -v curl >/dev/null 2>&1; then
    info "Warning: curl not found — skipping server removal"
    return 0
  fi
  if ! command -v jq >/dev/null 2>&1; then
    info "Warning: jq not found — skipping server removal"
    return 0
  fi

  RMV_KEY_ID_FILE="$SSH_KEY_DIR/id_${RMV_HOST}.keyserver-id"
  if [ ! -f "$RMV_KEY_ID_FILE" ]; then
    info "Warning: no keyId stored for $RMV_HOST — skipping server removal"
    return 0
  fi
  RMV_KEY_ID=$(cat "$RMV_KEY_ID_FILE")

  info "Fetching delete challenge for $RMV_HOST/$RMV_USER..."
  RMV_CHALLENGE_JSON=$(curl -sf "$KEYS_SERVER_URL/keys/$RMV_HOST/$RMV_USER/$RMV_KEY_ID/challenge") \
    || { info "Warning: failed to fetch delete challenge — skipping server removal"; return 0; }

  RMV_CHALLENGE=$(printf '%s' "$RMV_CHALLENGE_JSON" | jq -r '.challenge')
  RMV_NAMESPACE=$(printf '%s' "$RMV_CHALLENGE_JSON" | jq -r '.namespace')

  if [ -z "$RMV_CHALLENGE" ] || [ "$RMV_CHALLENGE" = "null" ]; then
    info "Warning: key server returned invalid delete challenge — skipping server removal"
    return 0
  fi

  info "Signing delete challenge..."
  RMV_TMP=$(mktemp)
  printf '%s' "$RMV_CHALLENGE" > "$RMV_TMP"
  if ! ssh-keygen -Y sign -f "$RMV_PRIVATE_KEY" -n "$RMV_NAMESPACE" "$RMV_TMP" >/dev/null 2>&1; then
    rm -f "$RMV_TMP" "${RMV_TMP}.sig"
    info "Warning: ssh-keygen sign failed for $RMV_HOST — skipping server removal"
    return 0
  fi
  RMV_SIGNATURE=$(cat "${RMV_TMP}.sig")
  rm -f "$RMV_TMP" "${RMV_TMP}.sig"

  if [ -z "$RMV_SIGNATURE" ]; then
    info "Warning: ssh-keygen produced empty signature for $RMV_HOST — skipping server removal"
    return 0
  fi

  info "Removing key from $KEYS_SERVER_URL..."
  if jq -n \
    --arg challenge "$RMV_CHALLENGE" \
    --arg signature "$RMV_SIGNATURE" \
    '{"challenge":$challenge,"signature":$signature}' \
    | curl -sf -X DELETE \
        -H 'Content-Type: application/json' \
        "$KEYS_SERVER_URL/keys/$RMV_HOST/$RMV_USER/$RMV_KEY_ID" \
        --data-binary @- >/dev/null; then
    rm -f "$RMV_KEY_ID_FILE"
    success "Removed key for $RMV_HOST from key server"
  else
    info "Warning: failed to remove key from server for $RMV_HOST"
  fi
}

###############################################################################
# upload_to_key_server
# Shared helper used by the upload subcommand, and later by create (#5) and
# rotate/revoke (#6).
# Args: KEY_HOST   - key file stem (id_<KEY_HOST>) and the API {host} segment
#       REMOTE_USER - the API {user} segment
###############################################################################
upload_to_key_server() {
  UPL_KEY_HOST=$1
  UPL_REMOTE_USER=$2

  [ -z "$KEYS_SERVER_URL" ] && die "KEYS_SERVER_URL is not set"
  command -v curl >/dev/null 2>&1 || die "curl not found — install curl to use key server integration"
  command -v jq   >/dev/null 2>&1 || die "jq not found — install jq to use key server integration"

  UPL_KEY_BASE_NAME="id_$UPL_KEY_HOST"
  UPL_PRIVATE_KEY="$SSH_KEY_DIR/$UPL_KEY_BASE_NAME"
  UPL_PUBLIC_KEY="$SSH_KEY_DIR/$UPL_KEY_BASE_NAME.pub"

  [ ! -f "$UPL_PUBLIC_KEY" ]  && die "Public key does not exist: $UPL_PUBLIC_KEY"
  [ ! -f "$UPL_PRIVATE_KEY" ] && die "Private key does not exist: $UPL_PRIVATE_KEY"

  UPL_KEY_TYPE=$(cut -d' ' -f1 "$UPL_PUBLIC_KEY")
  case "$UPL_KEY_TYPE" in
    ssh-ed25519|sk-ssh-ed25519@openssh.com) ;;
    *) die "Key type '$UPL_KEY_TYPE' is not accepted by the key server (only ssh-ed25519 and sk-ssh-ed25519@openssh.com)" ;;
  esac

  info "Fetching add-challenge for $UPL_KEY_HOST/$UPL_REMOTE_USER..."
  CHALLENGE_JSON=$(curl -sf "$KEYS_SERVER_URL/keys/$UPL_KEY_HOST/$UPL_REMOTE_USER/add-challenge") \
    || die "Failed to fetch challenge from $KEYS_SERVER_URL"

  UPL_CHALLENGE=$(printf '%s' "$CHALLENGE_JSON" | jq -r '.challenge')
  UPL_NAMESPACE=$(printf '%s' "$CHALLENGE_JSON" | jq -r '.namespace')

  if [ -z "$UPL_CHALLENGE" ] || [ "$UPL_CHALLENGE" = "null" ]; then
    die "Key server returned an invalid challenge"
  fi
  if [ -z "$UPL_NAMESPACE" ] || [ "$UPL_NAMESPACE" = "null" ]; then
    die "Key server returned an invalid namespace"
  fi

  info "Signing challenge..."
  UPL_TMP=$(mktemp)
  printf '%s' "$UPL_CHALLENGE" > "$UPL_TMP"
  if ! ssh-keygen -Y sign -f "$UPL_PRIVATE_KEY" -n "$UPL_NAMESPACE" "$UPL_TMP" >/dev/null 2>&1; then
    rm -f "$UPL_TMP"
    die "ssh-keygen sign failed for $UPL_KEY_HOST"
  fi
  UPL_SIGNATURE=$(cat "${UPL_TMP}.sig")
  rm -f "$UPL_TMP" "${UPL_TMP}.sig"

  [ -z "$UPL_SIGNATURE" ] && die "ssh-keygen produced an empty signature for $UPL_KEY_HOST"

  info "Uploading public key to $KEYS_SERVER_URL..."
  UPL_PUBLIC_KEY_DATA=$(cat "$UPL_PUBLIC_KEY")
  REQUEST_BODY=$(jq -n \
    --arg key       "$UPL_PUBLIC_KEY_DATA" \
    --arg challenge "$UPL_CHALLENGE" \
    --arg signature "$UPL_SIGNATURE" \
    '{"key":$key,"challenge":$challenge,"signature":$signature}')

  RESPONSE=$(printf '%s' "$REQUEST_BODY" | curl -sf -X POST \
    -H 'Content-Type: application/json' \
    "$KEYS_SERVER_URL/keys/$UPL_KEY_HOST/$UPL_REMOTE_USER" \
    --data-binary @-) \
    || die "Failed to upload key to key server for $UPL_KEY_HOST"

  KEY_ID=$(printf '%s' "$RESPONSE" | jq -r '.keyId')
  if [ -z "$KEY_ID" ] || [ "$KEY_ID" = "null" ]; then
    die "Key server did not return a keyId"
  fi

  printf '%s\n' "$KEY_ID" > "$SSH_KEY_DIR/${UPL_KEY_BASE_NAME}.keyserver-id"
  success "Uploaded key for $UPL_KEY_HOST (keyId: $KEY_ID)"
}

###############################################################################
# upload_ssh_key
###############################################################################
upload_ssh_key() {
  HOST=
  REMOTE_USER=$USER
  while [ $# -gt 0 ]; do
    key="$1"
    case $key in
      -h|--host)
        HOST="$2"
        shift
        shift
        ;;
      -u|--user)
        REMOTE_USER="$2"
        shift
        shift
        ;;
      *)
        shift
        ;;
    esac
  done

  [ -z "$HOST" ] && die "--host not specified"
  [ -z "$REMOTE_USER" ] && die "--user not specified and \$USER is not set"

  HOST_FILE_HOST=$(find_host_file "$HOST")
  [ -z "$HOST_FILE_HOST" ] && die "Could not find host key for $HOST"

  upload_to_key_server "$HOST_FILE_HOST" "$REMOTE_USER"
}

###############################################################################
# audit_ssh_keys
###############################################################################
audit_ssh_keys() {
  for KEY_FILE in ~/.ssh/id_*; do
    if [ -f "$KEY_FILE.pub" ] && [ -f "$KEY_FILE" ] ; then
        FILENAME=$(basename "${KEY_FILE}")
        KEY=$(ssh-keygen -l -f "${KEY_FILE}")
        printf '%s: %s\n' "$FILENAME" "$KEY"
    fi
  done | sort | while IFS= read -r LINE; do
    info "$LINE"
  done

  if [ -f "$SSH_KEY_DIR/id_rsa" ]; then
    die "Warning: default id_rsa key files exists"
  fi
  if [ -f "$SSH_KEY_DIR/id_ed25519" ]; then
    info "Warning: default id_ed25519 key files exists"
  fi
}

###############################################################################
# main
###############################################################################

[ $# -lt 1 ] && die "No action specified"

ACTION=$1
shift

if [ "$ACTION" = "create" ]; then
  create_ssh_key "$@"
elif [ "$ACTION" = "alias" ]; then
  alias_ssh_key "$@"
elif [ "$ACTION" = "revoke" ]; then
  revoke_ssh_key "$@"
elif [ "$ACTION" = "rotate" ]; then
  rotate_ssh_key "$@"
elif [ "$ACTION" = "show" ]; then
  show_ssh_key "$@"
elif [ "$ACTION" = "use" ]; then
  use_ssh_key "$@"
elif [ "$ACTION" = "import" ]; then
  import_ssh_key "$@"
elif [ "$ACTION" = "upload" ]; then
  upload_ssh_key "$@"
elif [ "$ACTION" = "audit" ]; then
  audit_ssh_keys "$@"
elif [ "$ACTION" = "help"  ] || [ "$ACTION" = "--?" ] || [ "$ACTION" = "--help" ]; then
  info "SSH Key manager"
  info "Usage:"
  info "Generate a new SSH Key for a host"
  info " $PROG create --host <host> --comment <comment> [--no-password] [--user <user>]"
  info "Add an alias to use an existing key for another host"
  info " $PROG alias --host <host> --additional-host <host>"
  info "Revoke an SSH Key"
  info " $PROG revoke --host <host> [--user <user>]"
  info "Replace an SSH Key generating a new one"
  info " $PROG rotate --host <host> --comment <comment> [--no-password] [--user <user>]"
  info "Show the public key for a host"
  info " $PROG show --host <host>"
  info "Unlock an SSH Private key for a host and add to the ssh-agent"
  info " $PROG use --host <host>"
  info "Upload an existing key to the key server (requires KEYS_SERVER_URL env var)"
  info " $PROG upload --host <host> [--user <user>]"
  info "Audit the encryption details of all installed keys"
  info " $PROG audit"
else
  die "Unknown action: $ACTION"
fi
